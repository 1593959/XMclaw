#!/bin/sh
# XMclaw Companion - Gradle Wrapper
# This script requires Gradle to be installed or will use Android Studio's built-in Gradle

if command -v gradle >/dev/null 2>&1; then
    exec gradle "$@"
else
    echo "Gradle not found in PATH."
    echo "Please open this project in Android Studio, which will automatically configure Gradle."
    echo "Or install Gradle from https://gradle.org/install/"
    exit 1
fi
